{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "terraviz/hero",
	"version": "0.3.0",
	"title": "Terraviz Right-Now Hero",
	"category": "embed",
	"icon": "star-filled",
	"description": "Embed the Terraviz node's curated \"right now\" featured dataset, updated automatically.",
	"keywords": [ "terraviz", "globe", "featured", "hero", "noaa" ],
	"textdomain": "terraviz",
	"supports": {
		"html": false,
		"align": [ "wide", "full" ],
		"anchor": true
	},
	"attributes": {
		"origin": { "type": "string", "default": "" },
		"terrain": { "type": "boolean" },
		"labels": { "type": "boolean" },
		"borders": { "type": "boolean" },
		"rotate": { "type": "boolean" },
		"chat": { "type": "boolean" },
		"layout": { "type": "number", "default": 1 },
		"aspectRatio": { "type": "string", "default": "" },
		"poster": { "type": "boolean" },
		"interactive": { "type": "boolean", "default": true },
		"heading": { "type": "string", "default": "h3" },
		"showTitle": { "type": "boolean", "default": true },
		"showAbstract": { "type": "boolean", "default": true }
	},
	"editorScript": "file:./index.js",
	"style": "terraviz-embed"
}
